def _hook_action(tool: str, ti: dict) -> str | None:
    """把一次工具调用提炼成一行人话（喂给活动流 + 工位屏幕）。"""
    def short(s, n=120):
        s = str(s).replace("\n", " ").strip()
        return s if len(s) <= n else s[:n] + "…"

    if tool == "Bash":
        return f"$ {short(ti.get('command', ''))}"
    if tool == "Read":
        return f"读 {short(ti.get('file_path', ''))}"
    if tool in ("Edit", "MultiEdit"):
        return f"改 {short(ti.get('file_path', ''))}"
    if tool == "Write":
        return f"写 {short(ti.get('file_path', ''))}"
    if tool == "NotebookEdit":
        return f"改 {short(ti.get('notebook_path', ''))}"
    if tool == "Grep":
        return f"搜 {short(ti.get('pattern', ''))}"
    if tool == "Glob":
        return f"找 {short(ti.get('pattern', ''))}"
    if tool == "WebFetch":
        return f"抓取 {short(ti.get('url', ''))}"
    if tool == "WebSearch":
        return f"搜网 {short(ti.get('query', ''))}"
    if tool == "TodoWrite":
        return None  # 太碎，不进活动流
    if not tool:
        return None
    return short(tool, 40)


def cmd_hook(_args: list[str]):
    """Claude Code 的 PostToolUse 钩子目标：读 stdin 里的工具调用 JSON，结构化上报 dashboard。
    必须快、必须永不报错卡住 claude——所有异常一律静默退出 0。"""
    try:
        raw = sys.stdin.read()
        data = json.loads(raw) if raw.strip() else {}
    except Exception:
        return
    tool = data.get("tool_name", "") or ""
    ti = data.get("tool_input", {}) or {}
    action = _hook_action(tool, ti)
    if not action:
        return
    agent_id = self_id()
    if not agent_id:
        return
    # 一条进活动流（日志墙），一条更新工位屏幕的当前动作。短超时，dashboard 没响应也不拖累 claude。
    post("/api/events", {
        "type": "log", "agentId": agent_id,
        "log": {"level": "tool", "content": action[:200]},
    }, timeout=0.5)
    post("/api/events", {
        "type": "status", "agentId": agent_id,
        "status": "working", "currentAction": action[:180],
    }, timeout=0.5)


