# ---------- 输出解析器 ----------

CLAUDE_PATTERNS = [
    (re.compile(r"^[\s●]*Running.*?:\s*(.+)$"), "正在运行 {0}"),
    (re.compile(r"^[\s●]*(Reading|Writing|Editing)\s+(.+)$"), "{0} {1}"),
    (re.compile(r"^[\s●]*(Bash|Edit|Read|Write|Grep|Glob)\((.+)\)\s*$"), "{0} {1}"),
    (re.compile(r"^[\s●]*(Searching for|Looking up)\s+(.+)$"), "搜索 {1}"),
    (re.compile(r"Approved tool use:\s*(.+)$"), "已批准 {0}"),
    (re.compile(r"Tool result:"), "处理工具结果"),
]

WAITING_PATTERNS = [
    re.compile(r"\bDo you (want|approve|allow)\b", re.I),
    re.compile(r"\b\[y/n\]\b", re.I),
    re.compile(r"\bPress (Enter|Y) to\b", re.I),
    re.compile(r"\bwaiting for (input|approval)\b", re.I),
    re.compile(r"❯.*\?$"),
]

# 鉴权失败：claude/codex 没登录或凭证失效（401）。识别出来标"鉴权失败"，
# 别让它伪装成"thinking"误导 PM 和老板——一眼就知道该去 /login。
AUTH_FAIL_PATTERNS = [
    re.compile(r"Please run\s*/login", re.I),
    re.compile(r"401\s*Invalid authentication", re.I),
    re.compile(r"Failed to authenticate", re.I),
    re.compile(r"Invalid authentication credentials", re.I),
    re.compile(r"\bUnauthorized\b.*\b401\b|\b401\b.*\bUnauthorized\b", re.I),
]


def detect_auth_fail(line: str) -> bool:
    return any(p.search(line) for p in AUTH_FAIL_PATTERNS)


# 用量上限暂停：claude/Pro 额度用尽。识别出来标"⏸ 等额度"而非 lost，让狗挂着等额度恢复后续接，
# 而不是被当掉线丢掉。
USAGE_LIMIT_PATTERNS = [
    re.compile(r"Stop and wait for limit to reset", re.I),
    re.compile(r"\b(usage )?limit (reached|reset)", re.I),
    re.compile(r"reached your (usage )?limit", re.I),
    re.compile(r"limit will reset|resets? (at|in)\b", re.I),
    re.compile(r"\b\d+-hour limit", re.I),
    re.compile(r"Upgrade your plan", re.I),
]


def detect_usage_limit(line: str) -> bool:
    return any(p.search(line) for p in USAGE_LIMIT_PATTERNS)

SPINNER_RE = re.compile(r"^[\s⠀-⣿⠁-⠿⡀-⣿◐◓◑◒▁-▇\|/\-\\\.]*$")
ANSI_RE = re.compile(r"\x1b\[[0-9;?]*[A-Za-z]|\x1b\][^\x07]*\x07")


def strip_ansi(s: str) -> str:
    return ANSI_RE.sub("", s)


def detect_waiting(line: str) -> bool:
    return any(p.search(line) for p in WAITING_PATTERNS)


def detect_action(line: str, tool: str) -> str | None:
    if tool == "claude":
        for pat, tpl in CLAUDE_PATTERNS:
            m = pat.search(line)
            if m:
                try:
                    return tpl.format(*m.groups())
                except Exception:
                    return tpl
    # 通用：取首行非空内容
    clean = line.strip()
    if not clean:
        return None
    if SPINNER_RE.match(clean):
        return None
    if len(clean) > ACTION_BUF_LIMIT:
        clean = clean[:ACTION_BUF_LIMIT] + "…"
    return clean


# 启动命令 / 环境变量回显等噪音，不进活动流
NOISE_MARKERS = (
    "DOG_TASK_LABEL", "DOG_AGENT_ID", "DOG_TERMINAL_MARKER", "export PATH",
    ".dog-office/launch/", "append-system-prompt", "/dog' run --", "/dog run --",
)
TOOL_ACTION_PREFIXES = ("●", "Running", "Bash(", "Edit(", "Read(", "Write(",
                        "Grep(", "Glob(", "Search(", "Update(", "MultiEdit(")


def is_noise(s: str) -> bool:
    return any(m in s for m in NOISE_MARKERS)


def detect_tool_action(line: str, tool: str) -> str | None:
    """只识别"工具动作"（读写文件、跑命令、搜索…），不要泛化散文行——用于干净活动流。"""
    if tool == "claude":
        for pat, tpl in CLAUDE_PATTERNS:
            m = pat.search(line)
            if m:
                try:
                    return tpl.format(*m.groups())
                except Exception:
                    return tpl
    s = line.strip()
    if s.startswith(TOOL_ACTION_PREFIXES):
        return s[:200]
    return None


# ---------- HTTP 客户端 ----------

# dashboard 永远是本地 127.0.0.1。狗的环境里现在会被注入 http_proxy/https_proxy（为了让 claude 走代理连
# Anthropic），但本地上报绝不能走代理。用一个强制空代理的 opener，跟 NO_PROXY 设没设无关，彻底防呆。
_NOPROXY_OPENER = urllib.request.build_opener(urllib.request.ProxyHandler({}))


def post(path: str, body: dict, timeout: float = 1.5) -> dict | None:
    try:
        data = json.dumps(body).encode("utf-8")
        req = urllib.request.Request(
            f"{DASHBOARD_URL}{path}",
            data=data,
            headers={"Content-Type": "application/json"},
        )
        with _NOPROXY_OPENER.open(req, timeout=timeout) as resp:
            return json.loads(resp.read().decode("utf-8") or "{}")
    except urllib.error.HTTPError as e:
        # 4xx/5xx：把服务器返回的真实错误体透出来，而不是吞成"服务器无响应"
        try:
            return json.loads(e.read().decode("utf-8") or "{}")
        except Exception:
            return {"ok": False, "error": f"HTTP {e.code}"}
    except (urllib.error.URLError, TimeoutError, ConnectionError):
        return None


