# ---------- UI 规范库 ----------

def _uilib_load_index() -> dict:
    try:
        with open(UI_INDEX, "r", encoding="utf-8") as f:
            data = json.load(f)
        if isinstance(data, dict) and isinstance(data.get("specs"), list):
            return data
    except Exception:
        pass
    return {"version": 1, "specs": []}


def _uilib_save_index(data: dict):
    os.makedirs(UI_LIB_DIR, exist_ok=True)
    with open(UI_INDEX, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False, indent=2)


def _uilib_add(args: list[str]):
    if not args or args[0].startswith("-"):
        print(UILIB_USAGE, file=sys.stderr)
        sys.exit(2)
    slug = args[0]
    opts = {"design": None, "name": None, "summary": None,
            "tags": None, "tone": None, "source": None, "quality": "normal"}
    i = 1
    while i < len(args):
        key = args[i][2:] if args[i].startswith("--") else None
        if key in opts and i + 1 < len(args):
            opts[key] = args[i + 1]
            i += 2
        else:
            i += 1
    design_path = opts["design"] or os.path.join(os.getcwd(), "docs", "DESIGN.md")
    if not os.path.exists(design_path):
        print(f"✗ 找不到设计文件 {design_path}（用 --design 指定）", file=sys.stderr)
        sys.exit(1)
    with open(design_path, "r", encoding="utf-8") as f:
        design = f.read()
    spec_dir = os.path.join(UI_LIB_DIR, slug)
    os.makedirs(spec_dir, exist_ok=True)
    with open(os.path.join(spec_dir, "DESIGN.md"), "w", encoding="utf-8") as f:
        f.write(design)
    tags = [t.strip() for t in (opts["tags"] or "").replace("，", ",").split(",") if t.strip()]
    now = int(time.time() * 1000)
    meta = {
        "slug": slug,
        "name": opts["name"] or slug,
        "summary": opts["summary"] or "",
        "tags": tags,
        "tone": opts["tone"] or "",
        "source": opts["source"] or "",
        "quality": "good" if opts["quality"] == "good" else "normal",
        "updatedAt": now,
    }
    with open(os.path.join(spec_dir, "meta.json"), "w", encoding="utf-8") as f:
        json.dump(meta, f, ensure_ascii=False, indent=2)
    data = _uilib_load_index()
    specs = data.get("specs", [])
    existing = next((x for x in specs if x.get("slug") == slug), None)
    if existing:
        existing.update(meta)
    else:
        meta["createdAt"] = now
        specs.append(meta)
    data["specs"] = specs
    _uilib_save_index(data)
    print(f"✓ 已沉淀规范 [{slug}]「{meta['name']}」到 UI 规范库（当前共 {len(specs)} 份）")


def cmd_uilib(args: list[str]):
    sub = args[0] if args else "list"
    rest = args[1:]

    if sub in ("help", "-h", "--help"):
        print(UILIB_USAGE)
        return

    if sub in ("index", "json"):
        print(json.dumps(_uilib_load_index(), ensure_ascii=False, indent=2))
        return

    if sub in ("list", "ls"):
        specs = _uilib_load_index().get("specs", [])
        if not specs:
            print("（UI 规范库还是空的——放手新建第一份，验收通过后用 `dog uilib add` 沉淀回来）")
            return
        print(f"UI 规范库共 {len(specs)} 份：\n")
        for s in specs:
            star = " ★优质" if s.get("quality") == "good" else ""
            print(f"● [{s.get('slug')}] {s.get('name', '')}{star}")
            if s.get("tags"):
                print(f"  标签: {', '.join(s.get('tags', []))}")
            if s.get("summary"):
                print(f"  一句话: {s.get('summary', '')}")
            meta_line = "  ".join(
                x for x in (
                    f"基调: {s.get('tone')}" if s.get("tone") else "",
                    f"来源: {s.get('source')}" if s.get("source") else "",
                ) if x
            )
            if meta_line:
                print(f"  {meta_line}")
            print()
        return

    if sub == "search":
        q = " ".join(rest).strip().lower()
        if not q:
            print('用法: dog uilib search "<关键词>"', file=sys.stderr)
            sys.exit(2)
        hits = []
        for s in _uilib_load_index().get("specs", []):
            hay = " ".join([
                s.get("name", ""), s.get("summary", ""), s.get("tone", ""),
                " ".join(s.get("tags", [])),
            ]).lower()
            if q in hay:
                hits.append(s)
        if not hits:
            print(f"（没找到匹配「{q}」的规范——可以新建）")
            return
        for s in hits:
            print(f"● [{s.get('slug')}] {s.get('name', '')} — {s.get('summary', '')}")
        return

    if sub == "show":
        if not rest:
            print("用法: dog uilib show <slug>", file=sys.stderr)
            sys.exit(2)
        path = os.path.join(UI_LIB_DIR, rest[0], "DESIGN.md")
        if not os.path.exists(path):
            print(f"✗ 找不到规范 {rest[0]}（先 dog uilib list 看有哪些）", file=sys.stderr)
            sys.exit(1)
        with open(path, "r", encoding="utf-8") as f:
            sys.stdout.write(f.read())
        return

    if sub == "add":
        _uilib_add(rest)
        return

    print(UILIB_USAGE, file=sys.stderr)
    sys.exit(2)


def cmd_hire(args: list[str]):
    if not args:
        print('用法: dog hire <角色> --task "<任务>" [--tool X] [--model Y]', file=sys.stderr)
        sys.exit(2)
    role = args[0]
    task = tool = model = None
    i = 1
    while i < len(args):
        if args[i] == "--task" and i + 1 < len(args):
            task = args[i + 1]; i += 2
        elif args[i] == "--tool" and i + 1 < len(args):
            tool = args[i + 1]; i += 2
        elif args[i] == "--model" and i + 1 < len(args):
            model = args[i + 1]; i += 2
        else:
            i += 1
    if not task:
        print("✗ 缺少 --task", file=sys.stderr)
        sys.exit(2)
    resp = post("/api/hire", {
        "fromAgentId": self_id(),
        "role": role,
        "task": task,
        "tool": tool,
        "model": model,
    }, timeout=30)
    if resp and resp.get("ok"):
        print(f"✓ 已招聘 {role}，新成员正在入职")
    else:
        print(f"✗ 招聘失败: {(resp or {}).get('error', '服务器无响应')}", file=sys.stderr)
        sys.exit(1)


# ---------- 主流程 ----------

def parse_args(argv: list[str]) -> tuple[str | None, str | None, list[str]]:
    """
    返回 (task_label, agent_id, command_argv)
    支持:
      dog run "label" cmd args...
      dog run -- cmd args...
      dog run cmd args...   (label = 命令首词)
    """
    if not argv or argv[0] != "run":
        print(USAGE, file=sys.stderr)
        sys.exit(2)

    rest = argv[1:]
    if not rest:
        print("缺少要执行的命令", file=sys.stderr)
        sys.exit(2)

    label = os.environ.get("DOG_TASK_LABEL")
    agent_id = os.environ.get("DOG_AGENT_ID")

    # -- 分隔符
    if "--" in rest:
        i = rest.index("--")
        head = rest[:i]
        cmd = rest[i + 1:]
        if head and not label:
            label = head[0]
    else:
        # 第一个参数看起来像描述（非可执行）就当 label
        head_first = rest[0]
        if (
            not label
            and not head_first.startswith("-")
            and " " in head_first  # 多词描述
        ):
            label = head_first
            cmd = rest[1:]
        else:
            cmd = rest

    if not cmd:
        print("没有要执行的命令", file=sys.stderr)
        sys.exit(2)

    if not label:
        label = " ".join(cmd[:3])

    return label, agent_id, cmd


def main():
    label, agent_id, cmd = parse_args(sys.argv[1:])
    if not agent_id:
        agent_id = str(uuid.uuid4())

    tool = os.environ.get("DOG_TOOL") or guess_tool(cmd[0])
    dog_name = os.environ.get("DOG_NAME")
    role = os.environ.get("DOG_ROLE", "fullstack")  # 9 角色 id
    terminal_app = os.environ.get("DOG_TERMINAL_APP")  # Terminal | iTerm | Warp
    parent_id = os.environ.get("DOG_PARENT_ID")  # 从父进程继承
    project_id = os.environ.get("DOG_PROJECT_ID")  # 项目归属
    # 终端窗口标识：父狗如果有就继承；自己是根狗就用自己 id 短码
    terminal_marker = os.environ.get("DOG_TERMINAL_MARKER") or agent_id[:8]
    terminal_tty = os.ttyname(sys.stdin.fileno()) if sys.stdin.isatty() else None
    is_pm = role in ("pm", "manager")

    # 报告启动
    started_resp = post(
        "/api/events",
        {
            "type": "started",
            "agentId": agent_id,
            "taskLabel": label,
            "tool": tool,
            "role": role,
            "dogName": dog_name,
            "terminalApp": terminal_app,
            "parentId": parent_id,
            "terminalMarker": terminal_marker,
            "terminalTty": terminal_tty,
            "cwd": os.getcwd(),
            "command": " ".join(cmd),
            "projectId": project_id,
            "status": "working",
            "currentAction": "等你说项目目标…" if is_pm else "正在启动…",
        },
    )
    if started_resp:
        badge = "👔 PM" if is_pm else "🐕"
        parent_hint = f" (派自 {parent_id[:8]})" if parent_id else ""
        sys.stderr.write(f"\033[2m{badge} Dog Office: {started_resp.get('dogName','?')} 入职 [{agent_id[:8]}]{parent_hint}\033[0m\n")

    state = {
        "last_output_ts": time.time(),
        "running": True,
        "status": "working",
        "current_action": "正在启动…",
        "last_logged": None,   # 活动流去重：上一条记进日志墙的事件
        "limit_paused": False, # 撞用量上限暂停（区别于真掉线，进程退出后保持可续接）
    }

    # 准备给子进程的环境变量：
    # - 清掉 DOG_AGENT_ID（不让子进程误以为自己是我）
    # - 清掉 DOG_TOOL/DOG_ROLE/DOG_TASK_LABEL/DOG_NAME（这些是我自己的）
    # - 保留 DOG_TERMINAL_APP（同终端共享，子狗的按钮也能打开同一个窗口）
    # - 设 DOG_PARENT_ID=<我的 id>（子代孙代狗都能查到他爹）
    # 首条 prompt 注入：claude 会自动跑位置参数的任务，但 codex/hermes 等交互式工具不会
    # （它们只把 prompt 填进输入框、不自动回车）。这类工具裸起 TUI，由我在 TUI 就绪后注入首条 prompt。
    init_prompt = os.environ.get("DOG_INIT_PROMPT")

    child_env = os.environ.copy()
    for key in (
        "DOG_AGENT_ID", "DOG_TOOL", "DOG_ROLE",
        "DOG_TASK_LABEL", "DOG_NAME", "DOG_INIT_PROMPT"
    ):
        child_env.pop(key, None)
    child_env["DOG_PARENT_ID"] = agent_id
    child_env["DOG_TERMINAL_MARKER"] = terminal_marker  # 子狗用同一个窗口标记
    child_env["DOG_SELF_ID"] = agent_id  # 子进程内的 dog 子命令（send/submit）凭这个知道"我是谁"
    # DOG_PROJECT_ID 不清除，自然继承给子孙

    # === PTY pump 模式（像 script(1)）===
    # - 子进程 stdin/stdout/stderr 全接 PTY slave —— 这样 wrapper 持有的 master_fd
    #   既能截输出，又能把字节写进子进程的输入（消息直连的地基）。
    # - 父终端设 raw，把你的按键原样转发进 master（TUI 才能用方向键/单键/Ctrl-C）。
    # - server 通过 Unix socket 注入的消息也写进 master，等价于"在 agent 里打字+回车"。
    is_tty = sys.stdin.isatty()
    stdin_fd = sys.stdin.fileno() if is_tty else None
    saved_term = None  # 父终端原始 termios，退出时还原

    try:
        import pty
        master_fd, slave_fd = pty.openpty()

        # PTY 窗口大小同步父终端（让子进程知道屏幕多大）
        if is_tty:
            try:
                cols, rows = os.get_terminal_size()
                fcntl.ioctl(slave_fd, termios.TIOCSWINSZ,
                            struct.pack('HHHH', rows, cols, 0, 0))
            except Exception:
                pass

        proc = subprocess.Popen(
            cmd,
            stdin=slave_fd,   # 子进程从 PTY 读输入，master 写入 = 喂给它
            stdout=slave_fd,
            stderr=slave_fd,
            close_fds=True,
            preexec_fn=os.setsid,
            env=child_env,
        )
        os.close(slave_fd)

        # 把父终端切 raw：按键不被行缓冲/回显拦截，原样进 master 给子进程
        if is_tty:
            try:
                import tty as _tty
                saved_term = termios.tcgetattr(stdin_fd)
                _tty.setraw(stdin_fd)
            except Exception:
                saved_term = None

    except Exception:
        # 退化：没 PTY 直接 PIPE
        master_fd = None
        proc = subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            bufsize=1,
            text=True,
            env=child_env,
        )

    def restore_terminal():
        if saved_term is not None and stdin_fd is not None:
            try:
                termios.tcsetattr(stdin_fd, termios.TCSADRAIN, saved_term)
            except Exception:
                pass

    # 消息注入：把文字当作"粘贴 + 回车"写进子进程 PTY。
    # 用 bracketed paste（ESC[200~ … ESC[201~）包裹，保住多行不被提前提交，
    # 再补一个回车提交（等价于老方案的 Cmd+V 然后 Enter）。
    PASTE_START = b"\x1b[200~"
    PASTE_END = b"\x1b[201~"

    def inject_message(text: str):
        if master_fd is None or not text:
            return
        try:
            os.write(master_fd, PASTE_START + text.encode("utf-8") + PASTE_END)
            time.sleep(0.08)
            os.write(master_fd, b"\r")
        except OSError:
            pass

    # 窗口大小变化 → 通知子进程 PTY（让 TUI 重排）
    def on_winch(_signum, _frame):
        if master_fd is None or not is_tty:
            return
        try:
            cols, rows = os.get_terminal_size()
            fcntl.ioctl(master_fd, termios.TIOCSWINSZ,
                        struct.pack('HHHH', rows, cols, 0, 0))
        except Exception:
            pass

    signal.signal(signal.SIGWINCH, on_winch)

    # 注册 wrapper 自己的 PID（杀我会触发信号转发到子进程，并跑 finally 清理）
    post("/api/register-pid", {"agentId": agent_id, "pid": os.getpid()})

    # 信号转发：把信号传给子进程组
    def forward_signal(signum, _frame):
        try:
            os.killpg(os.getpgid(proc.pid), signum)
        except Exception:
            pass

    # SIGHUP（终端关闭）→ 跑清理 + 退出
    def graceful_exit_sighup(signum, _frame):
        try:
            os.killpg(os.getpgid(proc.pid), signal.SIGTERM)
        except Exception:
            pass
        # SystemExit 会触发 finally 块跑清理
        raise SystemExit(0)

    signal.signal(signal.SIGINT, forward_signal)
    signal.signal(signal.SIGTERM, forward_signal)
    signal.signal(signal.SIGHUP, graceful_exit_sighup)

    # 心跳线程
    def heartbeat():
        while state["running"]:
            time.sleep(HEARTBEAT_INTERVAL)
            now = time.time()
            # 长时间无输出 → thinking
            if state["status"] == "working" and now - state["last_output_ts"] > IDLE_TIMEOUT:
                state["status"] = "thinking"
                post("/api/events", {
                    "type": "status",
                    "agentId": agent_id,
                    "status": "thinking",
                    "currentAction": state["current_action"] or "思考中…"
                })
            post("/api/events", {"type": "heartbeat", "agentId": agent_id})

    threading.Thread(target=heartbeat, daemon=True).start()

    # 消息直连：开一个 Unix socket，server 把队友/PM 消息写进来，主循环注入子进程 PTY。
    # 路径由 agent_id 推导，server 端同样推导，无需注册握手。
    ipc_sock = None
    ipc_path = None
    try:
        os.makedirs(IPC_DIR, exist_ok=True)
        ipc_path = os.path.join(IPC_DIR, agent_id + ".sock")
        try:
            os.unlink(ipc_path)
        except OSError:
            pass
        ipc_sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        ipc_sock.bind(ipc_path)
        ipc_sock.listen(8)
        ipc_sock.setblocking(False)
        try:
            os.chmod(ipc_path, 0o600)
        except OSError:
            pass
    except Exception:
        ipc_sock = None
        ipc_path = None

    def inject_from_line(line_bytes: bytes):
        line = line_bytes.strip()
        if not line:
            return
        try:
            msg = json.loads(line.decode("utf-8"))
            text = msg.get("text", "")
        except Exception:
            text = line.decode("utf-8", errors="replace")
        if text:
            inject_message(text)

    # 输出读取
    buf = b""
    line_count = 0

    def emit_line(line: str):
        # 完整版：写到 stdout + 解析（用于退化路径）
        sys.stdout.write(line)
        sys.stdout.flush()
        emit_line_parse_only(line)

    def emit_line_parse_only(line: str):
        # 仅解析，不写 stdout（PTY 路径已经把原始 chunk 写过了）
        # 干净活动流：只把"有意义的事件"写进日志墙，散文行只用来更新工位屏幕当前动作。
        nonlocal line_count
        line_count += 1
        clean = strip_ansi(line).rstrip("\n\r")

        if not clean.strip():
            return
        # 启动命令 / 环境变量回显 → 噪音，丢弃
        if is_noise(clean):
            return

        # 0a) 用量上限：标"⏸ 等额度"，记下暂停，等额度恢复后可续接（不当掉线丢掉）
        if detect_usage_limit(clean):
            state["limit_paused"] = True
            state["status"] = "paused"
            if state["last_logged"] != "PAUSED":
                state["last_logged"] = "PAUSED"
                post("/api/events", {
                    "type": "status", "agentId": agent_id, "status": "paused",
                    "currentAction": "⏸ 撞用量上限，等额度恢复后可点「继续」续接",
                })
                post("/api/events", {
                    "type": "log", "agentId": agent_id,
                    "log": {"level": "warn",
                            "content": "⏸ 用量上限暂停：等额度恢复后在详情面板点「继续」续接。原文：" + clean[:120]},
                })
            return

        # 0) 鉴权失败（401/未登录）：标"鉴权失败"而非"thinking"，免得误导成"模型卡死"
        if detect_auth_fail(clean):
            state["status"] = "error"
            if state["last_logged"] != "AUTHFAIL":
                state["last_logged"] = "AUTHFAIL"
                post("/api/events", {
                    "type": "status", "agentId": agent_id, "status": "error",
                    "currentAction": "🔑 鉴权失败：需在终端 /login（凭证失效/401）",
                })
                post("/api/events", {
                    "type": "log", "agentId": agent_id,
                    "log": {"level": "error",
                            "content": "🔑 鉴权失败(401)：这只狗的工具没登录或凭证被踢下线，去终端 /login。原文：" + clean[:120]},
                })
            return

        # 1) 等待输入：有意义事件，记一条
        if detect_waiting(clean):
            state["status"] = "waiting"
            post("/api/events", {
                "type": "waiting",
                "agentId": agent_id,
                "status": "waiting",
                "currentAction": clean[:ACTION_BUF_LIMIT],
            })
            if state["last_logged"] != "WAIT":
                state["last_logged"] = "WAIT"
                post("/api/events", {
                    "type": "log",
                    "agentId": agent_id,
                    "log": {"level": "warn", "content": "⏳ 等待你回应：" + clean[:160]},
                })
            return

        # 2) 识别到的工具动作（读写文件 / 跑命令…）：记进活动流 + 更新当前动作
        tool_action = detect_tool_action(clean, tool)
        if tool_action:
            if tool_action != state["last_logged"]:
                state["last_logged"] = tool_action
                post("/api/events", {
                    "type": "log",
                    "agentId": agent_id,
                    "log": {"level": "tool", "content": tool_action[:200]},
                })
            state["current_action"] = tool_action
            state["last_output_ts"] = time.time()
            new_status = "working" if state["status"] in ("thinking", "waiting", "idle") else state["status"]
            state["status"] = new_status
            post("/api/events", {
                "type": "status",
                "agentId": agent_id,
                "status": new_status,
                "currentAction": tool_action,
                "progress": min(0.95, line_count / 200.0),
            })
            return

        # 3) 普通散文行：只更新工位屏幕的"当前动作"，不进日志墙
        action = detect_action(clean, tool)
        if action:
            state["current_action"] = action
            state["last_output_ts"] = time.time()
            if state["status"] in ("thinking", "waiting", "idle"):
                state["status"] = "working"
                post("/api/events", {
                    "type": "status",
                    "agentId": agent_id,
                    "status": "working",
                    "currentAction": action,
                    "progress": min(0.95, line_count / 200.0),
                })

    # 主循环：多路复用——子进程输出 / 你的键盘 / server 注入的消息
    try:
        if master_fd is not None:
            base_fds = [master_fd]
            if stdin_fd is not None:
                base_fds.append(stdin_fd)
            if ipc_sock is not None:
                base_fds.append(ipc_sock.fileno())
            conn_bufs = {}  # fileno -> [conn_socket, bytearray]

            # 首条 prompt 注入状态：等 TUI 渲染完（输出冒头后空闲 >1.5s）或最多 6s 后注入一次
            init_injected = init_prompt is None
            init_start = time.time()

            while True:
                watch = list(base_fds) + list(conn_bufs.keys())
                try:
                    rs, _, _ = select.select(watch, [], [], 0.5)
                except (OSError, ValueError):
                    break

                # 1) 子进程输出 → 透传你的终端 + 解析给 dashboard
                if master_fd in rs:
                    try:
                        chunk = os.read(master_fd, 4096)
                    except OSError:
                        break
                    if not chunk:
                        break
                    try:
                        os.write(sys.stdout.fileno(), chunk)
                    except OSError:
                        pass
                    buf += chunk
                    while b"\n" in buf:
                        line_bytes, buf = buf.split(b"\n", 1)
                        try:
                            line = line_bytes.decode("utf-8", errors="replace")
                        except Exception:
                            line = line_bytes.decode("latin-1", errors="replace")
                        emit_line_parse_only(line)

                # 2) 你的键盘 → 写进子进程 PTY（终端透明转发）
                if stdin_fd is not None and stdin_fd in rs:
                    try:
                        kin = os.read(stdin_fd, 4096)
                        if kin:
                            os.write(master_fd, kin)
                    except OSError:
                        pass

                # 3) 新的消息连接
                if ipc_sock is not None and ipc_sock.fileno() in rs:
                    try:
                        conn, _ = ipc_sock.accept()
                        conn.setblocking(False)
                        conn_bufs[conn.fileno()] = [conn, bytearray()]
                    except OSError:
                        pass

                # 4) 消息数据 → 注入子进程
                for cfd in list(conn_bufs.keys()):
                    if cfd not in rs:
                        continue
                    conn, cbuf = conn_bufs[cfd]
                    try:
                        data = conn.recv(8192)
                    except OSError:
                        data = b""
                    if not data:
                        try:
                            conn.close()
                        except OSError:
                            pass
                        del conn_bufs[cfd]
                        continue
                    cbuf += data
                    while b"\n" in cbuf:
                        nl = cbuf.index(b"\n")
                        inject_from_line(bytes(cbuf[:nl]))
                        del cbuf[:nl + 1]

                # 5) 交互式工具(codex/hermes)：TUI 就绪后注入首条 prompt + 回车（它们不自动跑）
                if not init_injected:
                    idle = time.time() - state["last_output_ts"]
                    elapsed = time.time() - init_start
                    if (line_count > 0 and idle > 1.5) or elapsed > 6:
                        inject_message(init_prompt)
                        init_injected = True

                if proc.poll() is not None and master_fd not in rs:
                    break
        else:
            assert proc.stdout
            for line in iter(proc.stdout.readline, ""):
                emit_line(line)
    finally:
        state["running"] = False
        restore_terminal()
        if ipc_sock is not None:
            try:
                ipc_sock.close()
            except Exception:
                pass
        if ipc_path:
            try:
                os.unlink(ipc_path)
            except OSError:
                pass
        rc = proc.wait()
        # flush 残留
        if buf:
            try:
                emit_line(buf.decode("utf-8", errors="replace"))
            except Exception:
                pass

        if state.get("limit_paused"):
            # 撞额度退出的：不当完成/出错，标 paused 让狗挂着等续接
            post("/api/events", {
                "type": "status",
                "agentId": agent_id,
                "status": "paused",
                "currentAction": "⏸ 额度暂停，等恢复后点「继续」续接",
            })
            sys.stderr.write(f"\033[2m🐕 Dog Office: 撞用量上限，已暂停（可续接）\033[0m\n")
        elif rc == 0:
            post("/api/events", {
                "type": "completed",
                "agentId": agent_id,
                "status": "done",
                "currentAction": "完成 ✓",
                "progress": 1.0
            })
            sys.stderr.write(f"\033[2m🐕 Dog Office: 任务完成 ✓\033[0m\n")
        else:
            post("/api/events", {
                "type": "error",
                "agentId": agent_id,
                "status": "error",
                "currentAction": f"退出码 {rc}",
            })
            sys.stderr.write(f"\033[2m🐕 Dog Office: 任务出错 (exit {rc})\033[0m\n")

        sys.exit(rc)


def guess_tool(cmd: str) -> str:
    base = os.path.basename(cmd).lower()
    for k in ("claude", "codex", "antigravity", "anti-gravity", "hermes"):
        if k in base:
            return k.replace("anti-gravity", "antigravity")
    return base or "custom"


